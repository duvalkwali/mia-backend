NODE_ENV=development
PORT=3000
# API path prefix segment: /api/<API_VERSION>/...
API_VERSION=v1
# winston level: error | warn | info | debug
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins.
# Production: set to the frontend's public origin, e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3001

DATABASE_URL=postgresql://user:password@localhost:5432/mia_db
REDIS_URL=redis://localhost:6379
# Alternative to REDIS_URL — build the URL from parts (managed providers):
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=true

# Required. Production refuses to boot if unset or left as "change-me".
# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRY=7d

# Ollama (local LLM) — https://ollama.com
# Pull models first:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_STRONG_MODEL=llama3.2
OLLAMA_EXTRACTION_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MAX_TOKENS=300
OLLAMA_TEMPERATURE=0.4
# AI call timeout in ms — 120000 for CPU inference; drop to ~30000 on a GPU
OLLAMA_TIMEOUT_MS=120000
# How long the model stays loaded after a request ('5m' Ollama default; '24h'
# avoids cold starts)
OLLAMA_KEEP_ALIVE=5m

# FAQ semantic search — embeddings are computed lazily once an FAQ has been
# used FAQ_EMBEDDING_THRESHOLD times; requires the Ollama embedding model
FAQ_EMBEDDING_ENABLED=false
FAQ_EMBEDDING_THRESHOLD=3

# Conversation memory (Redis) — how many recent turns are kept and for how long
MAX_EPHEMERAL_TURNS=3
EPHEMERAL_CONTEXT_TTL=1800
# Prompt template cache TTL in seconds
PROMPT_CACHE_TTL=3600

# WhatsApp Cloud API (Meta). All values arrive with the Meta app in Phase 6;
# required in production (boot refuses without them), optional in development.
# Verify token: any random string — you paste the same value into Meta's
# webhook config. Webhook secret: the Meta App Secret (HMAC verification).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
# Outbound-send fallbacks — per-tenant credentials live on
# Tenant.whatsappPhoneNumberId / Tenant.whatsappAccessToken; these env vars
# are the fallback while the pilot runs single-tenant.
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
