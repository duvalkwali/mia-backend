NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://user:password@localhost:5432/mia_db
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
JWT_EXPIRY=7d

# Ollama (local LLM) — https://ollama.com
# Pull models first:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_STRONG_MODEL=llama3.2
OLLAMA_EXTRACTION_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MAX_TOKENS=300
OLLAMA_TEMPERATURE=0.4

# WhatsApp Cloud API (Meta) — outbound-send fallbacks.
# Per-tenant credentials live on Tenant.whatsappPhoneNumberId /
# Tenant.whatsappAccessToken; these env vars are the fallback used while the
# pilot runs single-tenant (values arrive with the Meta app in Phase 6).
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
